# Environment variables required for local development
# Do NOT commit actual secret values. Copy this file to .env and fill in the values.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-only key for Supabase functions and migrations.
# This should never be included in client-side app builds.
SUPABASE_SERVICE_ROLE_KEY=
